{
  "manifest_version": 3,
  "name": "GPA Calc Extension",
  "description": "This extension calculates the GPA of FCAI students",
  "version": "0.1",
  "author": "Omar Abdelaziz",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "images/gpa-calc16.png",
      "32": "images/gpa-calc32.png",
      "48": "images/gpa-calc48.png",
      "128": "images/gpa-calc128.png"
    }
  },
  "icons": {
    "16": "images/gpa-calc16.png",
    "32": "images/gpa-calc32.png",
    "48": "images/gpa-calc48.png",
    "128": "images/gpa-calc128.png"
  },

  "content_scripts": [
    {
      "js": ["scripts/content.js"],
      "matches": ["http://193.227.14.58/*", "http://newecom.fci-cu.edu.eg/*"],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "webNavigation",
    "webRequest"
  ],
  "host_permissions": ["http://*/*"],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["scripts/inject.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
